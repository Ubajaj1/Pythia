# Copy this file to .env and fill in one provider's key.
# Pythia auto-detects: Anthropic → Groq → OpenAI → Ollama (in that order).

# --- Option 1: Groq (recommended — free tier, fast) ---
# Sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# --- Option 2: Anthropic ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Option 3: OpenAI ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Option 4: Ollama (local, no API key) ---
# Run with: docker compose --profile ollama up
# Then pull a model: docker compose exec ollama ollama pull llama3.1:8b
# OLLAMA_BASE_URL=http://ollama:11434  (set automatically in Docker)
